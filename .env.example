# OpenPoke Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenRouter API key for default LLM and embedding access
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: OpenAI-compatible LLM API configuration
# OPENPOKE_LLM_API_KEY=your_llm_api_key_here
# OPENPOKE_LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENPOKE_LLM_MODEL=openrouter/free
# OPENPOKE_INTERACTION_AGENT_MODEL=openrouter/free
# OPENPOKE_EXECUTION_AGENT_MODEL=openrouter/free
# OPENPOKE_EXECUTION_AGENT_SEARCH_MODEL=openrouter/free
# OPENPOKE_SUMMARIZER_MODEL=openrouter/free

# Optional: keep embeddings on a separate OpenAI-compatible endpoint.
# Useful when chat uses a local openai-oauth proxy but embeddings stay on OpenRouter.
# OPENPOKE_EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
# OPENPOKE_EMBEDDINGS_API_KEY=your_openrouter_api_key_here

# Optional: ChatGPT Plus via external openai-oauth proxy.
# Run first: npx @openai/codex login && npx openai-oauth
# The local proxy ignores the dummy key, but OpenPoke currently requires one.
# To keep OpenRouter credentials embeddings-only, put that key in
# OPENPOKE_EMBEDDINGS_API_KEY instead of OPENROUTER_API_KEY for this mode.
# OPENPOKE_LLM_BASE_URL=http://127.0.0.1:10531/v1
# OPENPOKE_LLM_API_KEY=unused
# OPENPOKE_LLM_MODEL=gpt-5.2
# OPENPOKE_INTERACTION_AGENT_MODEL=gpt-5.2
# OPENPOKE_EXECUTION_AGENT_MODEL=gpt-5.2
# OPENPOKE_SUMMARIZER_MODEL=gpt-5.2

# Optional: Signal messaging via signal-cli direct HTTP daemon
# Disabled by default. Empty allowlist denies all senders.
# OPENPOKE_SIGNAL_HTTP_URL=http://127.0.0.1:8080
# OPENPOKE_SIGNAL_ACCOUNT=+15551234567
# OPENPOKE_SIGNAL_ALLOWED_SENDERS=+15557654321

# Optional: local read-only calendar access from an exported .ics file
# OPENPOKE_CALENDAR_ICS_PATH=/absolute/path/to/calendar.ics
# OPENPOKE_CALENDAR_REFRESH_SECONDS=60
